# ── Postgres (app DB — RLS lives here; do not share with Langfuse) ───────────
POSTGRES_USER=terramind
POSTGRES_PASSWORD=terramind-dev-password
POSTGRES_DB=terramind
POSTGRES_PORT=5432

# terramind_app: non-superuser role the API connects as; RLS applies to it.
# Created by backend/scripts/postgres-init.sh on fresh volume init.
APP_DB_USER=terramind_app
APP_DB_PASSWORD=terramind-app-dev-password

# Superuser DSN — used by the migrate service only (alembic upgrade head).
DATABASE_URL_MIGRATE=postgresql+asyncpg://terramind:terramind-dev-password@db:5432/terramind
# App-role DSN — used by the api service at runtime; RLS enforced.
DATABASE_URL=postgresql+asyncpg://terramind_app:terramind-app-dev-password@db:5432/terramind

# ── Langfuse DB (dedicated container; separate from app DB) ──────────────────
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse-dev-password
LANGFUSE_DB_NAME=langfuse

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Vault (dev mode — ephemeral; not for production) ─────────────────────────
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token
VAULT_PORT=8200

# ── Langfuse ─────────────────────────────────────────────────────────────────
LANGFUSE_PORT=3001
# Generate each with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
# LANGFUSE_SECRET_KEY: internal signing key used by the Langfuse server itself.
LANGFUSE_SECRET_KEY=replace-with-openssl-rand-base64-32
LANGFUSE_SALT=replace-with-openssl-rand-base64-32
# Project-level SDK API keys: seeded into Langfuse via LANGFUSE_INIT_PROJECT_*
# and used by the api service Python SDK to authenticate. The server seeds these
# on first boot (down -v required to re-seed after changing values).
LANGFUSE_PUBLIC_KEY=pk-lf-terra-mind-dev
LANGFUSE_SDK_SECRET_KEY=sk-lf-terra-mind-dev
# Langfuse seed admin account (used to log into the UI at localhost:3001).
LANGFUSE_INIT_USER_EMAIL=admin@terra-mind.dev
LANGFUSE_INIT_USER_PASSWORD=change-me-before-demo

# ── Service ports ─────────────────────────────────────────────────────────────
API_PORT=8000
FRONTEND_ADMIN_PORT=8501
FRONTEND_USER_PORT=5173

# CORS allow-list for the browser portal (comma-separated origins). NEVER "*".
CORS_ALLOW_ORIGINS=http://localhost:5173

# ── Secrets seeded into Vault by vault-init on first boot ────────────────────
# vault kv put secret/anthropic api_key=...
# vault kv put secret/jwt signing_key=...
# Never commit real values. Replace before running compose.
ANTHROPIC_API_KEY=sk-ant-placeholder
JWT_SIGNING_KEY=replace-with-openssl-rand-base64-32
